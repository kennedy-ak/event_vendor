# Ghana Events Marketplace - Environment Variables
# Copy this file to .env and fill in your actual values

# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,your-production-domain.com

# Database Configuration
# For Development (SQLite is used by default)
# For Production with PostgreSQL + PostGIS:
# DB_NAME=ghana_events_db
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=Ghana Events <noreply@ghanaevents.com>

# Cloud Storage (AWS S3 or DigitalOcean Spaces)
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=your-bucket.s3.amazonaws.com

# For DigitalOcean Spaces instead of AWS S3:
# AWS_S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
# AWS_S3_CUSTOM_DOMAIN=your-bucket.nyc3.digitaloceanspaces.com

# Paystack Payment Gateway
PAYSTACK_PUBLIC_KEY=pk_test_your-public-key
PAYSTACK_SECRET_KEY=sk_test_your-secret-key

# Site Configuration
SITE_URL=http://localhost:8000
SITE_NAME=Ghana Events Marketplace
